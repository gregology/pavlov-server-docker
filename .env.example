# =============================================================================
# Pavlov VR Dedicated Server Configuration
# =============================================================================
# Copy this file to .env and customize values.

# --- Server Variant ---
# Controls which Pavlov build is installed via SteamCMD beta branch.
#   default      = PC stable
#   beta_server  = PC beta
#   shack        = Shack (Quest) stable
#   shack_beta   = Shack (Quest) beta
BETA_BRANCH=default

# --- Network ---
# Main game port (UDP). Players connect to this port.
GAME_PORT=7777
# Secondary port is always GAME_PORT + 400. Set this manually if you change GAME_PORT.
SECONDARY_PORT=8177
# RCON port (TCP). Used by admin tools to send commands to the server.
RCON_PORT=9100

# --- Server Identity ---
SERVER_NAME=Pavlov VR Server
MAX_PLAYERS=16
# API key (required for server browser listing — see README.md for how to obtain one)
API_KEY=
# Server password (leave empty for public server)
SERVER_PASSWORD=

# --- RCON ---
RCON_ENABLED=true
RCON_PASSWORD=

# --- Gameplay ---
SECURED=true
CUSTOM_SERVER=true
VERBOSE_LOGGING=false
COMPETITIVE=false
WHITELIST=false
REFRESH_LIST_TIME=120
# 0=Unlimited, 1=Limited Generic, 2=Limited Specific, 3=Custom, 4=Special, 5=Boxless
LIMITED_AMMO_TYPE=0
TICK_RATE=90
TIME_LIMIT=60
AFK_TIME_LIMIT=300
BALANCE_TABLE_URL=

# --- Map Rotation ---
# Semicolon-separated list of map rotation entries.
# Custom maps use UGC prefix + mod.io resource ID (https://mod.io/g/pavlov).
# Example: (MapId="datacenter", GameMode="DM");(MapId="UGC2773760", GameMode="TDM")
#
# Game modes: DM, TDM, SND, KOTH, GUN, OITC, TANKTDM, TTT, TTTclassic,
#             WW2GUN, ZWV, HIDE, INFECTION, PUSH, PH
MAP_ROTATION=(MapId="datacenter", GameMode="DM")

# --- Advanced ---
# Additional lines to append to Game.ini (for settings not covered above).
# Use \n for newlines.
ADDITIONAL_GAME_INI=

# Skip SteamCMD update on container start (faster restarts during development).
SKIP_UPDATE=false
